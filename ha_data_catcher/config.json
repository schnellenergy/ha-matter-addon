{
  "name": "HA Data Catcher",
  "description": "Collects Home Assistant events in real-time, enriches them with Custom Storage metadata, and streams them to Firestore and BigQuery.",
  "version": "1.0.0",
  "slug": "ha_data_catcher",
  "init": false,
  "startup": "services",
  "boot": "auto",
  "arch": [
    "aarch64",
    "amd64",
    "armhf",
    "armv7",
    "i386"
  ],
  "hassio_api": true,
  "hassio_role": "default",
  "options": {
    "hub_id": "",
    "custom_storage_url": "http://homeassistant:8100",
    "ha_token": "",
    "debug": false
  },
  "schema": {
    "hub_id": "str?",
    "custom_storage_url": "str?",
    "ha_token": "password?",
    "debug": "bool?"
  }
}
